---
// Ocean State Digital - Coming Soon
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ocean State Digital</title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        @import url('https://fonts.cdnfonts.com/css/hero-beam');

        @property --eyebrow-hue {
            syntax: '<angle>';
            initial-value: 334.44deg;
            inherits: false;
        }

        @keyframes hueCycle {
            from {
                --eyebrow-hue: 334.44deg;
            }
            to {
                --eyebrow-hue: 694.44deg;
            }
        }

        /* Perfect font fallback for HERO BEAM — metrics generated with Capsize */
        @font-face {
            font-family: 'HERO BEAM Fallback';
            src: local('Arial'), local('ArialMT');
            ascent-override: 111.4502%;
            descent-override: 75.7861%;
            line-gap-override: 0%;
            size-adjust: 112.1577%;
        }

        /* Perfect font fallback for DM Sans — metrics generated with Capsize */
        @font-face {
            font-family: 'DM Sans Fallback';
            src: local('Arial'), local('ArialMT');
            ascent-override: 94.9001%;
            descent-override: 29.6563%;
            line-gap-override: 0%;
            size-adjust: 104.531%;
        }

        @keyframes scaleDownBounce {
            from {
                transform: scale(2.5);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            overflow: hidden;
        }

        body {
            background-color: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            font-family: 'HERO BEAM', 'HERO BEAM Fallback', Arial, sans-serif;
        }

        .hero {
            text-align: center;
            animation: scaleDownBounce 1.2s linear(
                0, 0.004, 0.016, 0.035, 0.063 9.1%, 0.141, 0.25, 0.391, 0.563, 0.765, 1,
                0.891, 0.813 45.5%, 0.785, 0.766, 0.754, 0.75, 0.754, 0.766, 0.785, 0.813 63.6%, 0.891, 1 72.7%,
                0.973, 0.953, 0.941, 0.938, 0.941, 0.953, 0.973, 1,
                0.988, 0.984, 0.988, 1
            ) both;
        }

        .eyebrow {
            font-family: 'DM Sans', 'DM Sans Fallback', Arial, sans-serif;
            font-size: 1.125rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: oklch(0.77 0.26 var(--eyebrow-hue));
            margin-bottom: 1.5rem;
            animation: hueCycle 8s linear infinite;
        }

        h1 {
            font-family: 'HERO BEAM', 'HERO BEAM Fallback', Arial, sans-serif;
            font-size: clamp(2.5rem, 8vw, 5rem);
            color: #353535;
            line-height: 1.1;
        }

        .corner {
            position: fixed;
            width: auto;
            height: auto;
            object-fit: contain;
            pointer-events: none;
            z-index: 0;
        }

        .corner.top-left,
        .corner.top-right {
            max-width: clamp(70px, 10vw, 120px);
            max-height: clamp(85px, 15vh, 190px);
        }

        .corner.bottom-left,
        .corner.bottom-right {
            max-width: clamp(70px, 10vw, 120px);
            max-height: clamp(85px, 15vh, 190px);
        }

        .corner.top-left {
            top: 0;
            left: 0;
        }

        .corner.top-right {
            top: 0;
            right: 0;
        }

        .corner.bottom-left {
            bottom: 0;
            left: 0;
        }

        .corner.bottom-right {
            bottom: 0;
            right: 0;
        }
    </style>
</head>
<body>
    <img src="/top-left.png" alt="" class="corner top-left" aria-hidden="true">
    <img src="/top-right.png" alt="" class="corner top-right" aria-hidden="true">
    <img src="/bottom-left.png" alt="" class="corner bottom-left" aria-hidden="true">
    <img src="/bottom-right.png" alt="" class="corner bottom-right" aria-hidden="true">
    <div class="hero">
        <p class="eyebrow">Coming Soon</p>
        <h1>Ocean State Digital</h1>
    </div>
</body>
</html>
