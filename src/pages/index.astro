---
// Ocean State Digital - Coming Soon
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ocean State Digital</title>
    <link rel="icon" href="/favicon.ico?v=3" sizes="any">
    <meta http-equiv="Cache-Control" content="public, max-age=31536000, immutable">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="preload" as="image" href="/logo.png?v=3">
    <link rel="preload" as="video" href="/video.mp4?v=3" type="video/mp4">
    <link rel="preload" as="video" href="/video-reverse.mp4?v=3" type="video/mp4">
    <style>
        @import url('https://fonts.cdnfonts.com/css/hero-beam');

        @property --eyebrow-hue {
            syntax: '<angle>';
            initial-value: 334.44deg;
            inherits: false;
        }

        @keyframes hueCycle {
            from {
                --eyebrow-hue: 334.44deg;
            }
            to {
                --eyebrow-hue: 694.44deg;
            }
        }

        /* Perfect font fallback for HERO BEAM — metrics generated with Capsize */
        @font-face {
            font-family: 'HERO BEAM Fallback';
            src: local('Arial'), local('ArialMT');
            ascent-override: 111.4502%;
            descent-override: 75.7861%;
            line-gap-override: 0%;
            size-adjust: 112.1577%;
        }

        /* Perfect font fallback for DM Sans — metrics generated with Capsize */
        @font-face {
            font-family: 'DM Sans Fallback';
            src: local('Arial'), local('ArialMT');
            ascent-override: 94.9001%;
            descent-override: 29.6563%;
            line-gap-override: 0%;
            size-adjust: 104.531%;
        }

        @keyframes scaleDownBounce {
            from {
                transform: scale(2.5);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            width: 100dvw;
            height: 100dvh;
            overflow: hidden;
        }

        body {
            background-color: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            font-family: 'HERO BEAM', 'HERO BEAM Fallback', Arial, sans-serif;
        }

        .hero {
            text-align: center;
            animation: scaleDownBounce 1.2s linear(
                0, 0.004, 0.016, 0.035, 0.063 9.1%, 0.141, 0.25, 0.391, 0.563, 0.765, 1,
                0.891, 0.813 45.5%, 0.785, 0.766, 0.754, 0.75, 0.754, 0.766, 0.785, 0.813 63.6%, 0.891, 1 72.7%,
                0.973, 0.953, 0.941, 0.938, 0.941, 0.953, 0.973, 1,
                0.988, 0.984, 0.988, 1
            ) both;
        }

        .eyebrow {
            font-family: 'DM Sans', 'DM Sans Fallback', Arial, sans-serif;
            font-size: 1.125rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: oklch(0.77 0.26 var(--eyebrow-hue));
            margin-bottom: 1.5rem;
            animation: hueCycle 8s linear infinite;
        }

        h1 {
            font-family: 'HERO BEAM', 'HERO BEAM Fallback', Arial, sans-serif;
            font-size: clamp(3.2rem, 8dvw, 5rem);
            color: #353535;
            line-height: 1.2;
        }

        .logo-wrapper {
            position: relative;
            display: inline-block;
            margin-bottom: 1rem;
            cursor: pointer;
            width: clamp(260px, 22dvw, 280px);
            aspect-ratio: 1 / 1;
        }

        .logo-wrapper img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            z-index: 1;
            transition: opacity 0.3s ease;
        }

        .logo-wrapper video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            pointer-events: none;
            z-index: 2;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .logo-wrapper.playing img,
        .logo-wrapper:hover img {
            opacity: 0;
        }

        .logo-wrapper.playing .video-forward,
        .logo-wrapper:hover .video-forward {
            opacity: 1;
        }

        .logo-wrapper.reversing img {
            opacity: 0;
        }

        .logo-wrapper.reversing .video-reverse {
            opacity: 1;
        }

        .corner {
            position: fixed;
            width: auto;
            height: auto;
            object-fit: contain;
            pointer-events: none;
            z-index: 0;
        }

        .corner.top-left,
        .corner.top-right {
            max-width: clamp(100px, 10dvw, 120px);
            max-height: clamp(100px, 15dvh, 190px);
        }

        .corner.bottom-left,
        .corner.bottom-right {
            max-width: clamp(70px, 10dvw, 150px);
            max-height: clamp(85px, 15dvh, 200px);
        }

        .corner.top-left {
            top: 0;
            left: 0;
        }

        .corner.top-right {
            top: 0;
            right: 0;
        }

        .corner.bottom-left {
            bottom: 0;
            left: 0;
        }

        .corner.bottom-right {
            bottom: 0;
            right: 0;
        }
    </style>
</head>
<body>
    <img src="/top-left.png?v=3" alt="" class="corner top-left" aria-hidden="true">
    <img src="/top-right.png?v=3" alt="" class="corner top-right" aria-hidden="true">
    <img src="/bottom-left.png?v=3" alt="" class="corner bottom-left" aria-hidden="true">
    <img src="/bottom-right.png?v=3" alt="" class="corner bottom-right" aria-hidden="true">
    <div class="hero">
        <div class="logo-wrapper">
            <img src="/logo.png?v=3" alt="Ocean State Digital">
            <video class="video-forward" src="/video.mp4?v=3" muted playsinline preload="auto"></video>
            <video class="video-reverse" src="/video-reverse.mp4?v=3" muted playsinline preload="auto"></video>
        </div>
        <p class="eyebrow">Coming Soon</p>
        <h1>Ocean State Digital</h1>
    </div>
    <script>
        const wrapper = document.querySelector('.logo-wrapper');
        const forwardVideo = wrapper.querySelector('.video-forward');
        const reverseVideo = wrapper.querySelector('.video-reverse');
        let isHovering = false;

        function resetVisuals() {
            forwardVideo.pause();
            reverseVideo.pause();
            wrapper.classList.remove('playing', 'reversing');
        }

        function fullReset() {
            resetVisuals();
            forwardVideo.currentTime = 0;
            reverseVideo.currentTime = 0;
        }

        function playForward() {
            fullReset();
            wrapper.classList.add('playing');
            forwardVideo.play().catch(() => {});
        }

        function playReverse() {
            wrapper.classList.remove('playing');
            wrapper.classList.add('reversing');
            reverseVideo.currentTime = 0;
            reverseVideo.play().catch(() => {});
        }

        // Desktop hover
        wrapper.addEventListener('mouseenter', () => {
            if (window.matchMedia('(hover: hover)').matches && !isHovering) {
                isHovering = true;
                playForward();
            }
        });

        wrapper.addEventListener('mouseleave', () => {
            if (window.matchMedia('(hover: hover)').matches) {
                isHovering = false;
                fullReset();
            }
        });

        // Mobile / touch tap
        wrapper.addEventListener('touchstart', (e) => {
            e.preventDefault();
            if (wrapper.classList.contains('playing') || wrapper.classList.contains('reversing')) {
                fullReset();
            } else {
                playForward();
            }
        }, { passive: false });

        // When forward video ends, play reverse
        forwardVideo.addEventListener('ended', () => {
            playReverse();
        });

        // When reverse video ends, fade to logo then fully reset
        reverseVideo.addEventListener('ended', () => {
            resetVisuals();
            setTimeout(() => {
                forwardVideo.currentTime = 0;
                reverseVideo.currentTime = 0;
            }, 350);
        });
    </script>
</body>
</html>
